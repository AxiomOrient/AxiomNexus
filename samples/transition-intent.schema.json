{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "axiomnexus/transition-intent.schema.json",
  "title": "TransitionIntent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "work_id",
    "agent_id",
    "lease_id",
    "expected_rev",
    "kind",
    "patch",
    "proof_hints"
  ],
  "properties": {
    "work_id": {
      "type": "string",
      "format": "uuid"
    },
    "agent_id": {
      "type": "string",
      "format": "uuid"
    },
    "lease_id": {
      "type": "string",
      "format": "uuid"
    },
    "expected_rev": {
      "type": "integer",
      "minimum": 0
    },
    "kind": {
      "type": "string",
      "enum": [
        "propose_progress",
        "complete",
        "block"
      ]
    },
    "patch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "resolved_obligations",
        "declared_risks"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "resolved_obligations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "maxItems": 64
        },
        "declared_risks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "maxItems": 64
        }
      }
    },
    "note": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 4000
    },
    "proof_hints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "value"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "maxItems": 64
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "block"
          }
        }
      },
      "then": {
        "required": [
          "note"
        ],
        "properties": {
          "note": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4000
          }
        }
      }
    }
  ]
}
